# Environment Variables for Viking Fuel
# Copy this file to .env and fill in your actual values

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://vikingfuel.se

# Supabase Configuration (if using Supabase for backend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Payment Processing (Stripe)
# Get your keys from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key_here
# Create products and prices in https://dashboard.stripe.com/products
# Replace with your actual price IDs
NEXT_PUBLIC_STRIPE_PRICE_ID_1=price_1REPLACE_THIS_1
NEXT_PUBLIC_STRIPE_PRICE_ID_3=price_1REPLACE_THIS_3
NEXT_PUBLIC_STRIPE_PRICE_ID_6=price_1REPLACE_THIS_6
STRIPE_SECRET_KEY=sk_live_your_secret_key_here

# Analytics (Google Analytics)
NEXT_PUBLIC_GA_MEASUREMENT_ID=your-google-analytics-id

# AdSense (if using Google AdSense)
NEXT_PUBLIC_ADSENSE_ID=your-adsense-id

# AI API Keys (if using AI features)
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
PERPLEXITY_API_KEY=your-perplexity-api-key